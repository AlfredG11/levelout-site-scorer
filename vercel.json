{
  "version": 2,
  "builds": [
    {
      "src": "api/census.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/census", "dest": "/api/census.js" },
    { "src": "/(.*)", "dest": "/dist/$1" }
  ]
}
